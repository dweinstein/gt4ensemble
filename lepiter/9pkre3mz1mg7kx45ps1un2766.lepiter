				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "Ensemble is a project and task management system built as inspectable Smalltalk objects with Lepiter persistence. This page documents the architecture and design decisions."
			},
			{
				"__type" : "textSnippet",
				"children" : {
					"__type" : "snippets",
					"items" : [ ]
				},
				"createEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"createTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-04-06T20:27:38.015057-04:00"
					}
				},
				"editEmail" : {
