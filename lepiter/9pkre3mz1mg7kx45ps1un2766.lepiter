					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"createTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-04-06T20:29:26.304764-04:00"
					}
				},
				"editEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"editTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-04-06T20:29:26.304764-04:00"
					}
				},
				"uid" : {
					"__type" : "uid",
					"uidString" : "/oGBOByJRu6mLSIeYImEMA=="
				},
				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "Each project is a Lepiter page. The page's first child is a {{gtClass:GtEnsembleProjectSnippet}} storing project metadata (name, directory, description, status). Subsequent children are {{gtClass:GtEnsembleTaskSnippet}} instances — one per task.\n\n**Snippet setters** follow the idiomatic Lepiter pattern:\n1. Set the ivar\n2. Call `self updateEditTimeAndEmail` to stamp the edit time\n3. Call `self announceContentChangedBy: self` to notify the UI\n\n**Syncing** between domain objects and snippets is bidirectional:\n- Domain → Snippet: setters on {{gtClass:GtEnsembleProject}} and {{gtClass:GtEnsembleTask}} call `syncToSnippet`\n- Snippet → Domain: snippet setters call `syncFromSnippet` on the linked domain object\n- A `syncing` guard ivar prevents re-entrant loops in both directions"
			},
			{
				"__type" : "textSnippet",
				"children" : {
					"__type" : "snippets",
					"items" : [ ]
				},
				"createEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"createTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-04-06T20:29:33.68787-04:00"
					}
				},
				"editEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"editTime" : {
					"__type" : "time",
					"time" : {
