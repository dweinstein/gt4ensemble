				},
				"code" : "| view |\nview := GtPhlowColumnedListView new.\nview items: [ {\n\t{ 'project' . '(ignored)' . 'Shows all projects via GtEnsembleProjectBoardElement' }.\n\t{ 'task' . 'a project name' . 'Shows tasks for that project via GtEnsembleTaskBoardElement' }.\n\t{ 'task' . 'nil' . 'Shows all tasks across all projects' }.\n} ].\nview column: 'boardType' text: [ :row | row first ] weight: 0.3.\nview column: 'projectName' text: [ :row | row second ] weight: 0.3.\nview column: 'Behavior' text: [ :row | row third ] weight: 0.6.\nview asElement",
				"elementHeight" : 120,
				"codeHeight" : 50,
				"codeVisible" : false
