					"uidString" : "XOTmZw2pQUaSMCxuJjb8/w=="
				},
				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "# Domain Model"
			},
			{
				"__type" : "textSnippet",
				"children" : {
					"__type" : "snippets",
					"items" : [ ]
				},
				"createEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"createTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-04-06T20:27:49.930767-04:00"
					}
				},
				"editEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"editTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-04-06T20:27:49.930767-04:00"
					}
				},
				"uid" : {
					"__type" : "uid",
					"uidString" : "Aeby3fwtSE20OMvW9YAwyQ=="
				},
				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "The core domain has three layers:\n\n**Board** ({{gtClass:GtEnsembleBoard}}) — the top-level singleton managing all projects. Loaded via `GtEnsembleBoard current`. Scans all loaded Lepiter databases for ensemble snippets.\n\n**Project** ({{gtClass:GtEnsembleProject}}) — a named project with status, directory, description, and a collection of tasks. Each project is backed by a Lepiter page containing a {{gtClass:GtEnsembleProjectSnippet}}.\n\n**Task** ({{gtClass:GtEnsembleTask}}) — an individual task with title, status, priority, notes, and tags. Each task is backed by a {{gtClass:GtEnsembleTaskSnippet}} on the project's Lepiter page.\n\n**Tag** ({{gtClass:GtEnsembleTag}}) — a named, colored label that can be assigned to tasks for cross-cutting categorization."
			},
			{
				"__type" : "textSnippet",
				"children" : {
					"__type" : "snippets",
					"items" : [ ]
				},
				"createEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"createTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-04-06T20:28:07.272596-04:00"
					}
				},
				"editEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"editTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-04-06T20:28:07.272596-04:00"
